        {
          "name": "Create Booking By Guest Info",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// สุ่มชื่อและราคา เพื่อให้เทสเคสหลากหลาย",
                  "const firstnames = [\"Somsak\", \"Wichai\", \"Ananda\", \"Lisa\", \"Boo\"];",
                  "const lastnames = [\"Deepak\", \"Rambo\", \"Blackpink\", \"Advanced\", \"Testing\"];",
                  "pm.variables.set(\"random_firstname\", firstnames[Math.floor(Math.random() * firstnames.length)]);",
                  "pm.variables.set(\"random_lastname\", lastnames[Math.floor(Math.random() * lastnames.length)]);",
                  "pm.variables.set(\"random_price\", Math.floor(Math.random() * 5000) + 1000);",
                  "console.log(\"สุ่มชื่อแขกเป็น: \" + pm.variables.get(\"random_firstname\"));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//เช็คว่าสร้างสำเร็จไหม (200 OK)",
                  "pm.test(\"Status code is 200 - Create Success\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "//ดึงค่า bookingid มาเก็บไว้ในถัง Environment",
                  "const jsonData = pm.response.json();",
                  "const bookingId = jsonData.bookingid;",
                  "pm.environment.set(\"latest_booking_id\", bookingId);",
                  "console.log(\"เก็บ Booking ID ไว้แล้ว: \" + bookingId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstname\" : \"{{random_firstname}}\",\n    \"lastname\" : \"{{random_lastname}}\",\n    \"totalprice\" : {{random_price}},\n    \"depositpaid\" : true,\n    \"bookingdates\" : {\n        \"checkin\" : \"2026-01-01\",\n        \"checkout\" : \"2026-01-05\"\n    },\n    \"additionalneeds\" : \"Breakfast\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/booking",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        },
