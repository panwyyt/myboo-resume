  "item": [
    {
      "name": "Admin Services",
      "item": [
        {
          "name": "Remove aditionalNeeds",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. เช็คว่าเซิร์ฟเวอร์ยอมให้แก้ไหม (200 OK)",
                  "pm.test(\"PATCH ผ่านฉลุย! (200 OK)\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 2. เช็คว่าค่าโดนลบจริงหรือเปล่า",
                  "const responseData = pm.response.json();",
                  "pm.test(\"ล้างข้อมูล additionalneeds เรียบร้อยแล้ว\", function () {",
                  "    pm.expect(responseData.additionalneeds).to.equal(\"\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Cookie",
                "value": "token={{token}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"additionalneeds\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/booking/{{latest_booking_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking",
                "{{latest_booking_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete By Latest BookingID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//เช็ค Status Code (สำหรับ API เจ้านี้ ถ้าลบสำเร็จเขาจะตอบกลับมาว่า 201 Created ครับ)",
                  "pm.test(\"ลบข้อมูลสำเร็จ! (201 Created)\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "//เคลียร์ค่า ID ในถัง environment",
                  "pm.environment.unset(\"latest_booking_id\");",
                  "",
                  "console.log(\"🗑️ ลบข้อมูล ID ล่าสุดทิ้งเรียบร้อยแล้ว!\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Cookie",
                "value": "token={{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/booking/{{latest_booking_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking",
                "{{latest_booking_id}}"
              ]
            }
          },
          "response": []
        }
      ],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "const authRequest = {                               //ใช้ POST ไปดึง Token มาก่อน",
              "    url: pm.environment.get(\"base_url\") + \"/auth\",   //Endpoint เพื่อขอ toke",
              "    method: 'POST', ",
              "    header: {",
              "        'Content-Type': 'application/json'",
              "    },",
              "    body: {                                         // ใส่รหัสผ่านลงในตัวเครื่อง (Body) โดยแปลงจาก Object เป็น String ก่อนส่งจริง",
              "        mode: 'raw',",
              "        raw: JSON.stringify({                       ",
              "            \"username\": \"admin\",                     // ยูสเซอร์เนมตามที่ API กำหนด",
              "            \"password\": \"password123\"                 // รหัสผ่านตามที่ API กำหนด",
              "        })",
              "    }",
              "};",
              "",
              "pm.sendRequest(authRequest, (error, response) => {      //ใช้คำสั่ง pm.sendRequest เพื่อแอบไปล็อกอินให้เราก่อนที่จะเริ่มรัน Request จริงๆ",
              "    if (error) {                    ",
              "        console.error(\"ขอ Token ไม่สำเร็จ:\", error);       // เช็ค Error",
              "        return;",
              "    }",
              "    if (response.code === 200) {",
              "        const result = response.json();                    // แปลงข้อมูลที่เซิร์ฟเวอร์ส่งกลับมาให้กลายเป็น JSON เพื่อให้อ่านง่าย",
              "        pm.environment.set(\"token\", result.token);              //บันทึกกุญแจลงถัง (Environment Variable)",
              "        console.log(\"กุญแจทีไ่ด้มารหัสคือ: \" + result.token);",
              "    } else {",
              "        console.warn(\"ล็อกอินไม่ผ่าน! เช็ค Username/Password อีกทีนะ รหัสตอบกลับคือ: \" + response.code);          // กรณีใส่ไม่ใช่ 200",
              "    }",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              ""
            ]
          }
        }
      ]
    },
